# Upstream LLM provider — OpenAI-compatible base URL
# Examples:
#   https://api.openai.com/v1
#   https://openrouter.ai/api/v1
#   https://api.together.xyz/v1
UPSTREAM_BASE_URL=https://api.openai.com/v1

# Optional server-side fallback API key. If a client request omits the
# Authorization header, Heimdall will inject this key. Leave blank to
# require clients to send their own key.
UPSTREAM_API_KEY=

# Network timeouts in seconds (connect, read, total)
HTTP_CONNECT_TIMEOUT=10
HTTP_READ_TIMEOUT=120
HTTP_TOTAL_TIMEOUT=180

# Host/port for the gateway itself
HOST=0.0.0.0
PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Phase 3: Semantic layer (Llama Guard 3) ---
# Any OpenAI-compatible endpoint that serves Llama Guard 3.
#   Ollama:     http://localhost:11434/v1  + model=llama-guard3
#   OpenRouter: https://openrouter.ai/api/v1 + model=meta-llama/llama-guard-3-8b
SEMANTIC_ENABLED=true
SEMANTIC_BASE_URL=http://localhost:11434/v1
SEMANTIC_MODEL=llama-guard3
SEMANTIC_API_KEY=
# If true, block when Llama Guard is unreachable. Default: false (fail-open).
SEMANTIC_FAIL_CLOSED=false
SEMANTIC_TIMEOUT=15

# --- Phase 4: Telemetry ---
TELEMETRY_DB_PATH=telemetry/heimdall.sqlite3

# --- Phase 3: Policy Manager ---
# Number of false-positive analyst reports before a rule auto-suppresses.
# Set to 0 to disable auto-suppression entirely.
POLICY_DEFAULT_FP_THRESHOLD=5

# --- Geo-IP (optional) ---
# Point at a MaxMind GeoLite2-Country .mmdb file; requires `pip install maxminddb`.
# GEOIP_DB_PATH=/path/to/GeoLite2-Country.mmdb

# --- Dashboard (read by dashboard/.env.local; not by FastAPI) ---
# HEIMDALL_API_URL=http://127.0.0.1:8000
# HEIMDALL_API_TOKEN=
