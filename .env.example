# =============================================================================
# Heimdall — example environment file
# =============================================================================
# Copy to .env and edit. Heimdall reads this on startup via pydantic-settings.

# ----- Logging -----
LOG_LEVEL=INFO
LOG_FORMAT=text             # `text` for dev, `json` for production ingest

# ----- Listening -----
HOST=0.0.0.0
PORT=8000

# ----- Database -----
# SQLite (dev, single-user self-host):
DATABASE_URL=sqlite+aiosqlite:///telemetry/heimdall.sqlite3
# Postgres (production):
# DATABASE_URL=postgresql+asyncpg://heimdall:secret@db.neon.tech/heimdall

# Legacy: still works for back-compat, but DATABASE_URL is the canonical setting.
TELEMETRY_DB_PATH=telemetry/heimdall.sqlite3

# ----- Multi-tenancy & auth -----
# false  → single-user mode (no auth, "default" tenant)
# true   → multi-user SaaS (Clerk JWT or sk_hd_ key required)
MULTI_TENANT_MODE=false
DEFAULT_TENANT_ID=default

# Clerk — from https://dashboard.clerk.com/  → API Keys
# JWKS URL example: https://YOUR-APP.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_SECRET_KEY=

# Static admin token for ops/CI (curl health checks, scripts).
ADMIN_API_TOKEN=

# ----- Fallback upstream (used for the default tenant when MULTI_TENANT_MODE=false
#       AND no provider rows exist yet) -----
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=

# Network timeouts (seconds)
HTTP_CONNECT_TIMEOUT=10
HTTP_READ_TIMEOUT=120
HTTP_TOTAL_TIMEOUT=180

# ----- L2 semantic layer (Llama Guard 3) -----
SEMANTIC_ENABLED=true
SEMANTIC_BASE_URL=http://localhost:11434/v1
SEMANTIC_MODEL=llama-guard3
SEMANTIC_API_KEY=
SEMANTIC_FAIL_CLOSED=false
SEMANTIC_TIMEOUT=15

# ----- Policy auto-suppress -----
POLICY_DEFAULT_FP_THRESHOLD=5

# ----- AI Triage (Claude Haiku) -----
ANTHROPIC_API_KEY=
TRIAGE_MODEL=claude-haiku-4-5-20251001
TRIAGE_MAX_PER_MINUTE=30

# ----- Rate limiting (per source IP, applied to /v1/* only) -----
RATE_LIMIT_PER_MINUTE=600
RATE_LIMIT_PER_DAY=50000

# ----- Geo-IP (optional MaxMind DB for country lookup) -----
# GEOIP_DB_PATH=/path/to/GeoLite2-Country.mmdb

# ----- CORS (dashboard origins, comma-separated) -----
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ----- Observability -----
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05

# ----- Dashboard (read by dashboard/.env.local; not by FastAPI) -----
# HEIMDALL_API_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
